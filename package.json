{
  "name": "vectis-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:web": "node ./scripts/ensure-dev-web-port.mjs && pnpm --filter @new-start/sdk-ts build && node ./scripts/dev-web.mjs",
    "dev:desktop": "pnpm --filter @vectis/desktop dev",
    "build:desktop": "node ./scripts/build-desktop.mjs",
    "build:web-static": "node ./scripts/build-web-static.mjs",
    "ci:readiness": "node ./scripts/ci-readiness.mjs",
    "r7:desktop:release-smoke": "node ./scripts/r7-desktop-release-smoke.mjs",
    "r7:discovery-draft:smoke": "node ./scripts/r7-discovery-draft-import-smoke.mjs",
    "r7:mobile:android:init": "pnpm --filter @vectis/desktop run android:init",
    "r7:mobile:android:dev": "node ./scripts/r7-mobile-android-command.mjs dev",
    "r7:mobile:android:build": "node ./scripts/r7-mobile-android-command.mjs build",
    "r7:mobile:scaffold-smoke": "node ./scripts/r7-mobile-scaffold-smoke.mjs",
    "r7:mobile:ios:init": "pnpm --filter @vectis/desktop exec tauri ios init",
    "r7:mobile:ios:dev": "node ./scripts/r7-mobile-ios-command.mjs dev",
    "r7:mobile:ios:build": "node ./scripts/r7-mobile-ios-command.mjs build",
    "r7:ios:scaffold-smoke": "node ./scripts/r7-ios-scaffold-smoke.mjs",
    "r7:m2:remote-node:smoke": "node ./scripts/r7-m2-remote-node-smoke.mjs",
    "r7:mobile:readiness": "node ./scripts/r7-mobile-readiness.mjs",
    "r7:client:readiness": "node ./scripts/r7-client-readiness.mjs",
    "brand:icons": "pnpm --filter @vectis/desktop exec tauri icon assets/icon.svg -o src-tauri/icons",
    "verify:desktop": "cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "v1:preflight": "node ./scripts/v1-preflight.mjs",
    "v1:readiness": "node ./scripts/v1-preflight.mjs --with-typecheck",
    "v1:lane-fixtures": "node ./scripts/v1-lane-fixture-check.mjs",
    "v1:lane-fixtures:readiness": "node ./scripts/v1-lane-fixture-check.mjs --with-typecheck",
    "v1:ga6-drill": "node ./scripts/v1-ga6-drill.mjs",
    "v1:ga6-drill:release": "node ./scripts/v1-ga6-drill-release.mjs",
    "v1:evidence-manifest": "node ./scripts/v1-evidence-manifest.mjs",
    "v1:artifact-prune-plan": "node ./scripts/v1-artifact-prune-plan.mjs",
    "v1:export-audit-log-plan": "node ./scripts/v1-export-audit-log-plan.mjs",
    "v1:export-audit-log-plan:smoke": "node ./scripts/v1-export-audit-log-plan-smoke.mjs",
    "v1:build-release": "node ./scripts/build-release.mjs",
    "v1:resolve-release": "node ./scripts/resolve-release-binary.mjs",
    "v1:docker-smoke": "node ./scripts/docker-smoke.mjs",
    "v3:discovery-bridge:smoke": "node ./scripts/v3-discovery-bridge.mjs --smoke",
    "v3:discovery-bridge:e2e": "node ./scripts/v3-discovery-bridge-e2e.mjs",
    "v3:aperio-import:smoke": "node ./scripts/v3-aperio-import.mjs --smoke",
    "v3:aperio-live-drill": "node ./scripts/v3-aperio-live-drill.mjs",
    "v3:aperio-live-drill:live": "node ./scripts/v3-aperio-live-drill.mjs --live",
    "v3:aperio-live-drill:determinism": "node ./scripts/v3-aperio-live-drill-determinism.mjs",
    "v3:aperio-live-drill:determinism:live": "node ./scripts/v3-aperio-live-drill-determinism.mjs --live",
    "v3:discovery-readiness": "node ./scripts/v3-discovery-readiness.mjs",
    "generate:p2h-policy-fixtures": "node ./scripts/generate-p2h-policy-fixtures.mjs",
    "r2:evidence-export": "node ./scripts/r2-evidence-export.mjs",
    "r2:restore-drill": "node ./scripts/r2-restore-drill.mjs",
    "r2:evidence-pack": "node ./scripts/r2-evidence-pack.mjs",
    "r4:client-audit": "node ./scripts/r4-client-audit.mjs",
    "r8:transport:smoke": "node ./scripts/r8-transport-smoke.mjs",
    "r2:exchange-drill": "node ./scripts/r2-exchange-drill.mjs",
    "r2:genesis-drill": "node ./scripts/r2-genesis-drill.mjs",
    "r5:policy-pack:export": "node ./scripts/r5-policy-pack-export.mjs",
    "r5:policy-pack:import-drill": "node ./scripts/r5-policy-pack-import-drill.mjs",
    "r5:two-node:drill": "node ./scripts/r5-two-node-drill.mjs",
    "v3:discovery-federation:smoke": "node ./scripts/v3-discovery-federation-merge.mjs --smoke",
    "r2:backup": "node ./scripts/r2-backup.mjs",
    "r2:deploy-smoke": "node ./scripts/r2-deploy-smoke.mjs",
    "v2:compute-receipt": "node ./scripts/v2-compute-receipt.mjs",
    "v2:compute-receipt:smoke": "node ./scripts/v2-compute-receipt.mjs --smoke",
    "r6:compute-job:drill": "node ./scripts/r6-compute-job-drill.mjs",
    "r6:lane-templates:smoke": "node ./scripts/r6-lane-templates-smoke.mjs",
    "r6:offline-lanes:smoke": "node ./scripts/r6-offline-lanes-smoke.mjs",
    "r6:post-deployment:readiness": "node ./scripts/r6-post-deployment-readiness.mjs",
    "r6:post-deployment:drill": "node ./scripts/r6-post-deployment-drill.mjs",
    "r6:post-deployment:multi-lane-drill": "node ./scripts/r6-post-deployment-multi-lane-drill.mjs",
    "r6:post-deployment:phase-c:packet": "node ./scripts/r6-post-deployment-phase-c-packet.mjs",
    "r6:post-deployment:phase-c:smoke": "node ./scripts/r6-post-deployment-phase-c-smoke.mjs",
    "repo:migrate-data-dirs": "node ./scripts/migrate-data-dirs.mjs",
    "typecheck": "pnpm -r --filter \"@new-start/*\" --filter \"@vectis/desktop\" typecheck",
    "build": "pnpm --filter @new-start/sdk-ts build && pnpm --filter @new-start/web build"
  }
}
