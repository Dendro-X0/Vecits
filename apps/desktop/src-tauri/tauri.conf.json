{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vectis",
  "version": "0.1.0",
  "identifier": "com.vectis.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://127.0.0.1:4900",
    "beforeDevCommand": "node ../../scripts/dev-tauri-web.mjs",
    "beforeBuildCommand": "echo \"web assets built by scripts/build-desktop.mjs\""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vectis",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/vectis-node"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
